@model IEnumerable<SecureNotesApp.Models.SavedAccount>

@{
    ViewData["Title"] = "Quản lý Tài khoản";
    // Layout = "_Layout"; // Bỏ comment nếu dùng chung Layout

    // KỸ THUẬT GOM NHÓM: Nhóm các tài khoản có cùng PlatformGroup (Ví dụ: gom hết Bank vào 1 nhóm)
    var groupedAccounts = Model != null ? Model.GroupBy(a => a.PlatformGroup ?? "Khác") : null;
}

<main class="main-content">
    <div class="page-header">
        <div class="header-top">
            <h1 class="page-title">
                <span>📋</span> Tài khoản
            </h1>
            <div class="header-actions">
                <!-- <button class="btn btn-secondary">
                    <svg width="18" height="18" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 4a1 1 0 011-1h16a1 1 0 011 1v2.586a1 1 0 01-.293.707l-6.414 6.414a1 1 0 00-.293.707V17l-4 4v-6.586a1 1 0 00-.293-.707L3.293 7.293A1 1 0 013 6.586V4z" /></svg> Lọc
                </button> -->

                <div style="position: relative; display: inline-block;">
                    <button class="btn btn-secondary" onclick="toggleFilterMenu()">
                        <svg width="18" height="18" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 4a1 1 0 011-1h16a1 1 0 011 1v2.586a1 1 0 01-.293.707l-6.414 6.414a1 1 0 00-.293.707V17l-4 4v-6.586a1 1 0 00-.293-.707L3.293 7.293A1 1 0 013 6.586V4z" />
                        </svg> Lọc
                    </button>

                    <div id="filterMenu" style="display: none; position: absolute; top: 110%; right: 0; background: white; border: 1px solid #eaeaea; border-radius: 8px; padding: 12px; box-shadow: 0 4px 15px rgba(0,0,0,0.08); z-index: 100; width: 180px;">
                        <div style="font-weight: bold; margin-bottom: 10px; font-size: 0.85rem; color: #888; text-transform: uppercase;">Chọn nền tảng</div>
                        
                        <label style="display: flex; align-items: center; margin-bottom: 8px; cursor: pointer; font-size: 0.95rem;">
                            <input type="radio" name="platformFilter" value="all" checked onclick="applyFilter('all')" style="margin-right: 8px;"> Tất cả
                        </label>
                        <label style="display: flex; align-items: center; margin-bottom: 8px; cursor: pointer; font-size: 0.95rem;">
                            <input type="radio" name="platformFilter" value="facebook" onclick="applyFilter('facebook')" style="margin-right: 8px;"> Facebook
                        </label>
                        <label style="display: flex; align-items: center; margin-bottom: 8px; cursor: pointer; font-size: 0.95rem;">
                            <input type="radio" name="platformFilter" value="gmail" onclick="applyFilter('gmail')" style="margin-right: 8px;"> Gmail
                        </label>
                        <label style="display: flex; align-items: center; margin-bottom: 8px; cursor: pointer; font-size: 0.95rem;">
                            <input type="radio" name="platformFilter" value="bank" onclick="applyFilter('bank')" style="margin-right: 8px;"> Ngân hàng
                        </label>
                        <label style="display: flex; align-items: center; margin-bottom: 8px; cursor: pointer; font-size: 0.95rem;">
                            <input type="radio" name="platformFilter" value="game" onclick="applyFilter('game')" style="margin-right: 8px;"> Game
                        </label>
                        <label style="display: flex; align-items: center; margin-bottom: 0; cursor: pointer; font-size: 0.95rem;">
                            <input type="radio" name="platformFilter" value="khác" onclick="applyFilter('khác')" style="margin-right: 8px;"> Khác
                        </label>
                    </div>
                </div>
                <button class="btn btn-primary" onclick="openAddAccountModal()">
                    <svg width="18" height="18" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 4v16m8-8H4" /></svg> Thêm Tài khoản
                </button>
            </div>
        </div>

        <div class="search-bar">
            <svg class="search-icon" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M21 21l-6-6m2-5a7 7 0 11-14 0 7 7 0 0114 0z" /></svg>
            <input type="text" class="search-input" placeholder="Tìm kiếm tài khoản..." id="searchInput" />
        </div>
    </div>

    <div class="account-groups">
        
        @if (groupedAccounts != null && groupedAccounts.Any())
        {
            foreach (var group in groupedAccounts)
            {
                <div class="account-group">
                    <div class="account-group-header">
                        <div class="account-group-title">
                            @if (group.Key.ToLower().Contains("facebook"))
                            {
                                <svg class="account-group-icon" fill="currentColor" viewBox="0 0 24 24"><path d="M24 12.073c0-6.627-5.373-12-12-12s-12 5.373-12 12c0 5.99 4.388 10.954 10.125 11.854v-8.385H7.078v-3.47h3.047V9.43c0-3.007 1.792-4.669 4.533-4.669 1.312 0 2.686.235 2.686.235v2.953H15.83c-1.491 0-1.956.925-1.956 1.874v2.25h3.328l-.532 3.47h-2.796v8.385C19.612 23.027 24 18.062 24 12.073z" /></svg>
                            }
                            else if (group.Key.ToLower().Contains("bank"))
                            {
                                <svg class="account-group-icon" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 10h18M7 15h1m4 0h1m-7 4h12a3 3 0 003-3V8a3 3 0 00-3-3H6a3 3 0 00-3 3v8a3 3 0 003 3z" /></svg>
                            }
                            else if (group.Key.ToLower().Contains("gmail") || group.Key.ToLower().Contains("email"))
                            {
                                <svg class="account-group-icon" fill="currentColor" viewBox="0 0 24 24"><path d="M24 5.457v13.909c0 .904-.732 1.636-1.636 1.636h-3.819V11.73L12 16.64l-6.545-4.91v9.273H1.636A1.636 1.636 0 0 1 0 19.366V5.457c0-2.023 2.309-3.178 3.927-1.964L5.455 4.64 12 9.548l6.545-4.91 1.528-1.145C21.69 2.28 24 3.434 24 5.457z" /></svg>
                            }
                            else if (group.Key.ToLower().Contains("game"))
                            {
                                <svg class="account-group-icon" fill="currentColor" viewBox="0 0 24 24">
                                    <path d="M21 6H3c-1.1 0-2 .9-2 2v8c0 1.1.9 2 2 2h18c1.1 0 2-.9 2-2V8c0-1.1-.9-2-2-2zm-10 7H8v3H6v-3H3v-2h3V8h2v3h3v2zm4.5 2c-.83 0-1.5-.67-1.5-1.5s.67-1.5 1.5-1.5 1.5.67 1.5 1.5-.67 1.5-1.5 1.5zm4-3c-.83 0-1.5-.67-1.5-1.5S18.67 9 19.5 9s1.5.67 1.5 1.5-.67 1.5-1.5 1.5z" />
                                </svg>
                            }
                            else
                            {
                                <svg class="account-group-icon" fill="currentColor" viewBox="0 0 24 24">
                                    <path d="M20.71 7.04c.39-.39.39-1.02 0-1.41l-2.34-2.34c-.39-.39-1.02-.39-1.41 0l-1.83 1.83 3.75 3.75 1.83-1.83zM3 17.25V21h3.75L17.81 9.94l-3.75-3.75L3 17.25z" />
                                </svg>
                            }
                            
                            @group.Key
                        </div>
                        <div class="card-actions">
                            <button class="btn-icon-small"><svg width="16" height="16" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 4v16m8-8H4" /></svg></button>
                        </div>
                    </div>

                    <div class="account-list">
                        @foreach (var acc in group)
                        {
                            <div class="account-item">

                                <!-- Username -->
                                <div class="account-field">
                                    <svg class="field-icon" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M16 7a4 4 0 11-8 0 4 4 0 018 0zM12 14a7 7 0 00-7 7h14a7 7 0 00-7-7z" /></svg>
                                    <div class="field-content"><div class="field-value">@acc.Username</div></div>
                                </div>

                                <!-- Password -->
                                <!-- <div class="account-field">
                                    <svg class="field-icon" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 7a2 2 0 012 2m4 0a6 6 0 01-7.743 5.743L11 17H9v2H7v2H4a1 1 0 01-1-1v-2.586a1 1 0 01.293-.707l5.964-5.964A6 6 0 1121 9z" /></svg>
                                    <div class="field-content"><div class="field-value masked-text">@acc.Password</div></div>
                                </div> -->

                                <div class="account-field">
                                    <svg class="field-icon" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 7a2 2 0 012 2m4 0a6 6 0 01-7.743 5.743L11 17H9v2H7v2H4a1 1 0 01-1-1v-2.586a1 1 0 01.293-.707l5.964-5.964A6 6 0 1121 9z" /></svg>
                                    <div class="field-content">
                                        @* Dùng input readonly type="password" để mặc định hiện dấu chấm *@
                                        <input type="password" class="field-value password-display" value="@acc.Password" readonly 
                                            style="background:none; border:none; color:inherit; font-family:inherit; width:100%; outline:none;">
                                    </div>
                                </div>

                                <!-- Phone Number -->
                                <div class="account-field">
                                    <svg class="field-icon" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 5a2 2 0 012-2h3.28a1 1 0 01.948.684l1.498 4.493a1 1 0 01-.502 1.21l-2.257 1.13a11.042 11.042 0 005.516 5.516l1.13-2.257a1 1 0 011.21-.502l4.493 1.498a1 1 0 01.684.949V19a2 2 0 01-2 2h-1C9.716 21 3 14.284 3 6V5z" /></svg>
                                    <div class="field-content"><div class="field-value">@(string.IsNullOrEmpty(acc.PhoneNumber) ? "N/A" : acc.PhoneNumber)</div></div>
                                </div>

                                <!-- Full Name & Email -->
                                <div class="account-field">
                                    <svg class="field-icon" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M13 16h-1v-4h-1m1-4h.01M21 12a9 9 0 11-18 0 9 9 0 0118 0z" /></svg>
                                    <div class="field-content">
                                        <div class="field-label">Tên</div>
                                        <div class="field-value" style="font-family: var(--font-primary)">@acc.FullName</div>
                                        
                                        @if(!string.IsNullOrEmpty(acc.Email))
                                        {
                                            <div class="field-label" style="margin-top: 4px">Email</div>
                                            <div class="field-value" style="font-family: var(--font-primary); font-size: 0.8rem;">@acc.Email</div>
                                        }
                                    </div>
                                </div>
                                <div class="account-actions">
                                    <!-- <button class="btn-icon-small" title="Xem"><svg width="16" height="16" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 12a3 3 0 11-6 0 3 3 0 016 0z" /><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M2.458 12C3.732 7.943 7.523 5 12 5c4.478 0 8.268 2.943 9.542 7-1.274 4.057-5.064 7-9.542 7-4.477 0-8.268-2.943-9.542-7z" /></svg></button> -->

                                    <button type="button" class="btn-icon-small" title="Xem mật khẩu" onclick="toggleAccountPassword(this)">
                                        <svg class="eye-icon" width="16" height="16" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                                            <path class="eye-open" stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 12a3 3 0 11-6 0 3 3 0 016 0z" />
                                            <path class="eye-open" stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M2.458 12C3.732 7.943 7.523 5 12 5c4.478 0 8.268 2.943 9.542 7-1.274 4.057-5.064 7-9.542 7-4.477 0-8.268-2.943-9.542-7z" />
                                        </svg>
                                    </button>


                                    <button type="button" class="btn-icon-small" title="Sửa"
                                            data-id="@acc.Id"
                                            data-platform="@acc.PlatformGroup"
                                            data-username="@acc.Username"
                                            data-password="@acc.Password"
                                            data-fullname="@acc.FullName"
                                            data-phone="@acc.PhoneNumber"
                                            data-email="@acc.Email"
                                            onclick="openEditAccountModal(this)">
                                        <svg width="16" height="16" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M11 5H6a2 2 0 00-2 2v11a2 2 0 002 2h11a2 2 0 002-2v-5m-1.414-9.414a2 2 0 112.828 2.828L11.828 15H9v-2.828l8.586-8.586z" /></svg>
                                    </button>
                                    <form asp-controller="Accounts" asp-action="Delete" asp-route-id="@acc.Id" method="post" style="display:inline;" 
                                        onsubmit="return confirm('Bạn có chắc chắn muốn xóa tài khoản @acc.Username này không? Hành động này không thể hoàn tác!');">
                                        
                                        <button type="submit" class="btn-icon-small text-danger" title="Xóa" style="background: none; border: none; cursor: pointer; padding: 0;">
                                            <svg width="16" height="16" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                                                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 7l-.867 12.142A2 2 0 0116.138 21H7.862a2 2 0 01-1.995-1.858L5 7m5 4v6m4-6v6m1-10V4a1 1 0 00-1-1h-4a1 1 0 00-1 1v3M4 7h16" />
                                            </svg>
                                        </button>
                                    </form>
                                </div>
                            </div>
                        }
                    </div>
                </div>
            }
        }
        else
        {
            <div class="text-center p-5 text-muted">
                <h4>Chưa có tài khoản nào được lưu.</h4>
                <p>Hãy bấm "Thêm Tài khoản" để bắt đầu.</p>
            </div>
        }
    </div>
</main>



<!-- Show Accounts Modal -->



<!-- Add Accounts Modal -->
<div id="addAccountModal" class="modal" style="display: none; position: fixed; top: 0; left: 0; width: 100%; height: 100%; background: rgba(0,0,0,0.5); z-index: 1000; justify-content: center; align-items: center;">
    <div class="modal-content" style="background: white; padding: 24px; border-radius: 12px; width: 100%; max-width: 500px; box-shadow: 0 10px 25px rgba(0,0,0,0.1);">
        
        <div class="modal-header" style="display: flex; justify-content: space-between; align-items: center; border-bottom: 1px solid #eee; padding-bottom: 16px; margin-bottom: 16px;">
            <h3 style="margin: 0; font-size: 1.25rem;">Thêm Tài Khoản Mới</h3>
            <button type="button" onclick="closeAddAccountModal()" style="background: none; border: none; font-size: 1.5rem; cursor: pointer;">&times;</button>
        </div>
        
        <div class="modal-body">
            <form asp-controller="Accounts" asp-action="Create" method="post">
                
                <div class="mb-3">
                    <label class="form-label fw-bold">Nền tảng <span class="text-danger">*</span></label>
                    <select name="PlatformGroup" class="form-select form-control" required>
                        <option value="" disabled selected>-- Chọn nền tảng --</option>
                        <option value="Facebook">Facebook</option>
                        <option value="Gmail">Gmail</option>
                        <option value="Bank">Ngân hàng (Bank)</option>
                        <option value="Game">Game</option>
                        <option value="Khác">Khác</option>
                    </select>
                </div>
                
                <div class="mb-3">
                    <label class="form-label fw-bold">Tên đăng nhập</label>
                    <input type="text" name="Username" class="form-control" placeholder="VD: user@example.com" />
                </div>
                
                <div class="mb-3">
                    <label class="form-label fw-bold">Mật khẩu <span class="text-danger">*</span></label>
                    <input type="password" name="Password" class="form-control" placeholder="Nhập mật khẩu" required />
                </div>

                <div class="row">
                    <div class="col-md-6 mb-3">
                        <label class="form-label fw-bold">Họ và Tên</label>
                        <input type="text" name="FullName" class="form-control" placeholder="Nguyễn Văn Anh" />
                    </div>
                    <div class="col-md-6 mb-3">
                        <label class="form-label fw-bold">Số điện thoại</label>
                        <input type="text" name="PhoneNumber" class="form-control" placeholder="0123456789" />
                    </div>
                </div>

                <div class="mb-3">
                    <label class="form-label fw-bold">Email khôi phục</label>
                    <input type="email" name="Email" class="form-control" placeholder="backup@example.com" />
                </div>
                
                <div class="text-end mt-4">
                    <button type="button" class="btn btn-light me-2 border" onclick="closeAddAccountModal()">Hủy</button>
                    <button type="submit" class="btn btn-primary">Lưu Tài Khoản</button>
                </div>
            </form>
        </div>
    </div>
</div>


<!-- Edit Accounts Modal -->
<div id="editAccountModal" class="modal" style="display: none; position: fixed; top: 0; left: 0; width: 100%; height: 100%; background: rgba(0,0,0,0.5); z-index: 1000; justify-content: center; align-items: center;">
    <div class="modal-content" style="background: white; padding: 24px; border-radius: 12px; width: 100%; max-width: 500px; box-shadow: 0 10px 25px rgba(0,0,0,0.1);">
        
        <div class="modal-header" style="display: flex; justify-content: space-between; align-items: center; border-bottom: 1px solid #eee; padding-bottom: 16px; margin-bottom: 16px;">
            <h3 style="margin: 0; font-size: 1.25rem;">Chỉnh Sửa Tài Khoản</h3>
            <button type="button" onclick="closeEditAccountModal()" style="background: none; border: none; font-size: 1.5rem; cursor: pointer;">&times;</button>
        </div>
        
        <div class="modal-body">
            <form asp-controller="Accounts" asp-action="Edit" method="post">
                <input type="hidden" name="Id" id="edit-Id" />
                
                <div class="mb-3">
                    <label class="form-label fw-bold">Nền tảng / Nhóm <span class="text-danger">*</span></label>
                    <select name="PlatformGroup" id="edit-PlatformGroup" class="form-select form-control" required>
                        <option value="Facebook">Facebook</option>
                        <option value="Gmail">Gmail</option>
                        <option value="Bank">Ngân hàng (Bank)</option>
                        <option value="Game">Tài khoản Game</option>
                        <option value="Khác">Khác</option>
                    </select>
                </div>
                
                <div class="mb-3">
                    <label class="form-label fw-bold">Tên đăng nhập</label>
                    <input type="text" name="Username" id="edit-Username" class="form-control" />
                </div>
                
                <div class="mb-3">
                    <label class="form-label fw-bold">Mật khẩu <span class="text-danger">*</span></label>
                    <input type="text" name="Password" id="edit-Password" class="form-control" required />
                </div>

                <div class="row">
                    <div class="col-md-6 mb-3">
                        <label class="form-label fw-bold">Họ và Tên</label>
                        <input type="text" name="FullName" id="edit-FullName" class="form-control" />
                    </div>
                    <div class="col-md-6 mb-3">
                        <label class="form-label fw-bold">Số điện thoại</label>
                        <input type="text" name="PhoneNumber" id="edit-PhoneNumber" class="form-control" />
                    </div>
                </div>

                <div class="mb-3">
                    <label class="form-label fw-bold">Email khôi phục</label>
                    <input type="email" name="Email" id="edit-Email" class="form-control" />
                </div>
                
                <div class="text-end mt-4">
                    <button type="button" class="btn btn-light me-2 border" onclick="closeEditAccountModal()">Hủy</button>
                    <button type="submit" class="btn btn-primary">Cập nhật</button>
                </div>
            </form>
        </div>
    </div>
</div>

<!-- Confirm password -->
<div id="verifyModal" class="modal" style="display:none; position:fixed; z-index:999; left:0; top:0; width:100%; height:100%; background:rgba(0,0,0,0.6);">
    <div style="background:white; width:300px; margin:15% auto; padding:20px; border-radius:12px; text-align:center;">
        <h3 style="margin-bottom:15px; color:#333;">Xác nhận danh tính</h3>
        <p style="font-size:0.9rem; color:#666;">Nhập mật khẩu đăng nhập để xem</p>
        <input type="password" id="confirmLoginPass" class="form-control" style="width:100%; margin:15px 0; padding:10px; border:1px solid #ddd; border-radius:6px;">
        <input type="hidden" id="targetAccountId">
        <div style="display:flex; gap:10px;">
            <button onclick="closeModal()" style="flex:1; padding:10px; border:none; border-radius:6px; cursor:pointer;">Hủy</button>
            <button onclick="submitVerify()" style="flex:1; padding:10px; border:none; background:#667eea; color:white; border-radius:6px; cursor:pointer;">Xác nhận</button>
        </div>
    </div>
</div>


@section Scripts {
    <script>
        function openAddAccountModal() {
            var modal = document.getElementById('addAccountModal');
            modal.style.display = 'flex';
        }

        function closeAddAccountModal() {
            var modal = document.getElementById('addAccountModal');
            modal.style.display = 'none';
        }


        // Edit 
        function openEditAccountModal(btn) {
            // Get data
            document.getElementById('edit-Id').value = btn.getAttribute('data-id');
            document.getElementById('edit-PlatformGroup').value = btn.getAttribute('data-platform');
            document.getElementById('edit-Username').value = btn.getAttribute('data-username');
            document.getElementById('edit-Password').value = btn.getAttribute('data-password');
            document.getElementById('edit-FullName').value = btn.getAttribute('data-fullname');
            document.getElementById('edit-PhoneNumber').value = btn.getAttribute('data-phone');
            document.getElementById('edit-Email').value = btn.getAttribute('data-email');

            // Show modal
            var modal = document.getElementById('editAccountModal');
            modal.style.display = 'flex';
        }

        function closeEditAccountModal() {
            var modal = document.getElementById('editAccountModal');
            modal.style.display = 'none';
        }
        

        window.onclick = function(event) {
            var addModal = document.getElementById('addAccountModal');
            var editModal = document.getElementById('editAccountModal');
            if (event.target == addModal) {
                addModal.style.display = 'none';
            }
            if (event.target == editModal) {
                editModal.style.display = 'none';
            }
        }


        // Search
        document.getElementById('searchInput').addEventListener('input', function (e) {
            var searchTerm = e.target.value.toLowerCase(); 
            
            var accountGroups = document.querySelectorAll('.account-group');

            accountGroups.forEach(function (group) {
                // Lấy tất cả các tài khoản con bên trong nhóm này
                var items = group.querySelectorAll('.account-item');
                var hasVisibleItem = false;

                items.forEach(function (item) {
                    var text = item.textContent.toLowerCase();

                    if (text.includes(searchTerm)) {
                        item.style.display = ''; 
                        hasVisibleItem = true;
                    } else {
                        item.style.display = 'none'; 
                    }
                });

                if (hasVisibleItem) {
                    group.style.display = 'block';
                } else {
                    group.style.display = 'none';
                }
            });
        });


        // Filter
        function toggleFilterMenu() {
            var menu = document.getElementById('filterMenu');
            menu.style.display = menu.style.display === 'none' ? 'block' : 'none';
        }

        function applyFilter(platform) {
            var accountGroups = document.querySelectorAll('.account-group');

            accountGroups.forEach(function (group) {
                var titleText = group.querySelector('.account-group-title').textContent.toLowerCase();

                if (platform === 'all' || titleText.includes(platform)) {
                    group.style.display = 'block';
                } else {
                    group.style.display = 'none';
                }
            });

            document.getElementById('filterMenu').style.display = 'none';
        }

        window.addEventListener('click', function(event) {
            var filterMenu = document.getElementById('filterMenu');
            var isClickInside = event.target.closest('#filterMenu') || event.target.closest('button[onclick="toggleFilterMenu()"]');
            
            if (!isClickInside && filterMenu.style.display === 'block') {
                filterMenu.style.display = 'none';
            }
        });




        function toggleAccountPassword(btn) {
            // Tìm đến account-item chứa nút vừa bấm
            const container = btn.closest('.account-item');
            const passwordInput = container.querySelector('.password-display');
            const eyeIcon = btn.querySelector('svg');

            if (passwordInput.type === "password") {
                passwordInput.type = "text";
                btn.style.color = "var(--primary-color)";
                btn.title = "Ẩn mật khẩu";
            } else {
                passwordInput.type = "password";
                btn.style.color = "inherit";
                btn.title = "Xem mật khẩu";
            }
        }




        let currentBtn = null;

        function toggleAccountPassword(btn) {
            const container = btn.closest('.account-item');
            const passwordInput = container.querySelector('.password-display');
            
            if (passwordInput.type === "text") {
                passwordInput.type = "password";
                btn.innerHTML = `<svg width="16" height="16" ... (Icon mắt đóng) ...></svg>`;
                return;
            }

            currentBtn = btn;
            document.getElementById('targetAccountId').value = btn.closest('.account-item').querySelector('[data-id]').dataset.id;
            document.getElementById('verifyModal').style.display = 'block';
        }

        async function submitVerify() {
            const id = document.getElementById('targetAccountId').value;
            const pass = document.getElementById('confirmLoginPass').value;

            const response = await fetch(`/Accounts/VerifyAndViewPassword`, {
                method: 'POST',
                headers: { 'Content-Type': 'application/x-www-form-urlencoded' },
                body: `id=${id}&loginPassword=${encodeURIComponent(pass)}`
            });

            if (response.ok) {
                const data = await response.json();
                const input = currentBtn.closest('.account-item').querySelector('.password-display');
                input.value = data.password; 
                input.type = "text"; 
                closeModal();
            } else {
                alert("Sai mật khẩu đăng nhập!");
            }
        }

        function closeModal() {
            document.getElementById('verifyModal').style.display = 'none';
            document.getElementById('confirmLoginPass').value = '';
        }
    </script>
}