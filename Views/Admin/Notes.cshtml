@model IEnumerable<SecureNotesApp.Models.Note>

@{
    ViewData["Title"] = "Quản lý ghi chú";
}

<div class="main-content">
    <div class="page-header" style="display: flex; justify-content: space-between; align-items: center; margin-bottom: 25px;">
        <h1 class="page-title">📝 Quản lý ghi chú hệ thống</h1>
        <div class="badge" style="background: #10b981; color: white; padding: 5px 15px; border-radius: 20px;">
            Tổng số: @Model.Count()
        </div>
    </div>

    <div class="table-container" style="background: white; border-radius: 12px; padding: 20px; box-shadow: 0 4px 6px rgba(0,0,0,0.05);">
        <table class="table" style="width: 100%; border-collapse: collapse;">
            <thead>
                <tr style="text-align: left; border-bottom: 2px solid #f3f4f6; color: #6b7280; font-size: 0.9rem;">
                    <th style="padding: 12px; width: 25%;">Tiêu đề</th>
                    <th style="padding: 12px; width: 35%;">Nội dung xem trước</th>
                    <th style="padding: 12px;">Người tạo</th>
                    <th style="padding: 12px;">Ngày tạo</th>
                    <th style="padding: 12px; text-align: right;">Thao tác</th>
                </tr>
            </thead>
            <tbody>
                @foreach (var note in Model)
                {
                    <tr style="border-bottom: 1px solid #f3f4f6;">
                        <td style="padding: 15px; font-weight: 600; color: #1f2937;">@note.Title</td>
                        <td style="padding: 15px; color: #6b7280; font-size: 0.85rem;">
                            @* Chỉ hiện 50 ký tự đầu *@
                            @(note.Content?.Length > 50 ? note.Content.Substring(0, 50) + "..." : note.Content)
                        </td>
                        <td style="padding: 15px;">
                            <span style="font-size: 0.85rem; color: #4b5563;">👤 @note.OwnerID</span>
                        </td>
                        <td style="padding: 15px; font-size: 0.8rem; color: #9ca3af;">
                            @note.CreatedAt.ToString("dd/MM/yyyy HH:mm")
                        </td>
                        <td style="padding: 15px; text-align: right;">
                            <form asp-action="DeleteNote" asp-route-id="@note.Id" method="post" 
                                  onsubmit="return confirm('Xóa ghi chú này sẽ không thể khôi phục. Sáng chắc chứ?');">
                                <button type="submit" class="btn-icon-small" style="border:none; background:none; cursor:pointer; color: #ef4444;">
                                    <svg width="20" height="20" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                                        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 7l-.867 12.142A2 2 0 0116.138 21H7.862a2 2 0 01-1.995-1.858L5 7m5 4v6m4-6v6m1-10V4a1 1 0 00-1-1h-4a1 1 0 00-1 1v3M4 7h16" />
                                    </svg>
                                </button>
                            </form>
                        </td>
                    </tr>
                }
            </tbody>
        </table>
    </div>
</div>