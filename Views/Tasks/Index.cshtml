@model IEnumerable<SecureNotesApp.Models.TodoTask>

@{
    ViewData["Title"] = "Quản lý Công Việc";
    var pendingTasks = Model?.Where(t => !t.IsCompleted).ToList() ?? new List<SecureNotesApp.Models.TodoTask>();
    var completedTasks = Model?.Where(t => t.IsCompleted).ToList() ?? new List<SecureNotesApp.Models.TodoTask>();
    
    int total = ViewBag.TotalTasks ?? 0;
    int progress = ViewBag.Progress ?? 0;
    int upcoming = ViewBag.UpcomingTasks ?? 0;
}

<main class="main-content">
    <div class="page-header">
        <div class="header-top">
            <h1 class="page-title">
                <span>📅</span> Tasks
            </h1>
            <div class="header-actions" style="display: flex; gap: 12px; align-items: center;">
                <div style="position: relative;">
                    <span style="position: absolute; left: 12px; top: 50%; transform: translateY(-50%); color: #94a3b8;">
                        <svg width="18" height="18" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M21 21l-6-6m2-5a7 7 0 11-14 0 7 7 0 0114 0z" /></svg>
                    </span>
                    <input type="text" id="taskSearchInput" placeholder="Tìm kiếm task...." style="padding: 8px 12px 8px 36px; border: 1px solid #cbd5e1; border-radius: 8px; outline: none; width: 250px; transition: 0.2s; font-size: 0.95rem;" onfocus="this.style.borderColor='#667eea'; this.style.boxShadow='0 0 0 3px rgba(102,126,234,0.1)'" onblur="this.style.borderColor='#cbd5e1'; this.style.boxShadow='none'">
                </div>

                <button class="btn btn-primary" onclick="openAddTaskModal()">
                    <svg width="18" height="18" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 4v16m8-8H4" /></svg> 
                    Thêm Công Việc
                </button>
            </div>
        </div>
    </div>

    <div class="stats-grid" style="margin-bottom: 30px;">
        <div class="stat-card">
            <div class="stat-icon" style="background: linear-gradient(135deg, #667eea 0%, #764ba2 100%);">
                <svg width="24" height="24" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 5H7a2 2 0 00-2 2v12a2 2 0 002 2h10a2 2 0 002-2V7a2 2 0 00-2-2h-2M9 5a2 2 0 002 2h2a2 2 0 002-2M9 5a2 2 0 012-2h2a2 2 0 012 2" /></svg>
            </div>
            <div class="stat-content">
                <div class="stat-label">Tổng số Task</div>
                <div class="stat-value">@total</div>
            </div>
        </div>

        <div class="stat-card" style="grid-column: span 2;">
            <div style="width: 100%;">
                <div style="display: flex; justify-content: space-between; align-items: flex-end; margin-bottom: 8px;">
                    <div>
                        <div class="stat-label">Tiến độ hoàn thành</div>
                        <div class="stat-value" style="font-size: 1.5rem;">@progress%</div>
                    </div>
                    <div style="font-size: 0.9rem; color: #64748b; font-weight: 500;">@ViewBag.CompletedTasks / @total task</div>
                </div>
                <div style="width: 100%; height: 10px; background: #e2e8f0; border-radius: 10px; overflow: hidden;">
                    <div style="width: @progress%; height: 100%; background: linear-gradient(90deg, #4facfe 0%, #00f2fe 100%); border-radius: 10px; transition: width 0.5s ease;"></div>
                </div>
            </div>
        </div>

        <div class="stat-card">
            <div class="stat-icon" style="background: linear-gradient(135deg, #f5576c 0%, #f093fb 100%);">
                <svg width="24" height="24" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 8v4l3 3m6-3a9 9 0 11-18 0 9 9 0 0118 0z" /></svg>
            </div>
            <div class="stat-content">
                <div class="stat-label">Hạn trong 7 ngày</div>
                <div class="stat-value" style="color: #e11d48;">@upcoming</div>
            </div>
        </div>
    </div>

    <div class="row" style="display: flex; gap: 24px; flex-wrap: wrap;">
        
        <div class="col-md-4" style="flex: 1; min-width: 300px;">
            <div style="background: white; border-radius: 16px; padding: 20px; box-shadow: 0 4px 15px rgba(0,0,0,0.03); height: 480px;">
                <div style="display: flex; justify-content: space-between; align-items: center; margin-bottom: 20px;">
                    <h3 style="margin: 0; font-size: 1.1rem; font-weight: 700; color: #1e293b;">Tháng @DateTime.Now.Month, @DateTime.Now.Year</h3>
                    <div style="display: flex; gap: 8px;">
                        <button class="btn-icon-small"><svg width="16" height="16" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 19l-7-7 7-7"/></svg></button>
                        <button class="btn-icon-small"><svg width="16" height="16" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 5l7 7-7 7"/></svg></button>
                    </div>
                </div>
                
                <div style="display: grid; grid-template-columns: repeat(7, 1fr); gap: 8px; text-align: center;">
                    <div style="font-size: 0.8rem; font-weight: 600; color: #94a3b8; padding-bottom: 8px;">T2</div>
                    <div style="font-size: 0.8rem; font-weight: 600; color: #94a3b8; padding-bottom: 8px;">T3</div>
                    <div style="font-size: 0.8rem; font-weight: 600; color: #94a3b8; padding-bottom: 8px;">T4</div>
                    <div style="font-size: 0.8rem; font-weight: 600; color: #94a3b8; padding-bottom: 8px;">T5</div>
                    <div style="font-size: 0.8rem; font-weight: 600; color: #94a3b8; padding-bottom: 8px;">T6</div>
                    <div style="font-size: 0.8rem; font-weight: 600; color: #94a3b8; padding-bottom: 8px;">T7</div>
                    <div style="font-size: 0.8rem; font-weight: 600; color: #94a3b8; padding-bottom: 8px;">CN</div>
                    
                    @for (int i = 1; i <= 31; i++)
                    {
                        bool hasTask = pendingTasks.Any(t => t.DueDate.Day == i && t.DueDate.Month == DateTime.Now.Month);
                        bool isToday = i == DateTime.Now.Day;
                        
                        <div style="aspect-ratio: 1; display: flex; flex-direction: column; align-items: center; justify-content: center; border-radius: 8px; font-size: 0.9rem; font-weight: 500; cursor: pointer; transition: 0.2s;
                                    @(isToday ? "background: #667eea; color: white; box-shadow: 0 4px 10px rgba(102,126,234,0.4);" : "color: #475569;")
                                    @(hasTask && !isToday ? "background: #f1f5f9; border: 1px solid #e2e8f0;" : "")">
                            @i
                            @if(hasTask && !isToday) { <div style="width: 4px; height: 4px; background: #ef4444; border-radius: 50%; margin-top: 2px;"></div> }
                        </div>
                    }
                </div>
            </div>
        </div>

        <div class="col-md-8" style="flex: 2; min-width: 400px;">
            <div class="custom-scroll" style="background: white; border-radius: 16px; padding: 24px; box-shadow: 0 4px 15px rgba(0,0,0,0.03); height: 480px; overflow-y: auto;">
                
                <h4 style="color: #334155; font-weight: 700; margin-bottom: 20px; font-size: 1.1rem;">📝 Việc Cần Làm</h4>

                @if (pendingTasks.Any())
                {
                    <div style="display: flex; flex-direction: column; gap: 12px;">
                        @foreach (var task in pendingTasks)
                        {
                            <div class="task-item" style="border: 1px solid #f1f5f9; border-radius: 12px; padding: 16px; display: flex; align-items: center; justify-content: space-between; transition: 0.2s;" onmouseover="this.style.borderColor='#cbd5e1'" onmouseout="this.style.borderColor='#f1f5f9'">
                                
                                <div style="display: flex; align-items: center; gap: 16px;">
                                    
                                    <form asp-controller="Tasks" asp-action="ToggleComplete" asp-route-id="@task.Id" method="post" style="margin: 0;" 
                                        onsubmit="return confirm('Bạn có chắc chắn đã hoàn thành công việc này chưa? 🏆');">
                                        <button type="submit" style="width: 24px; height: 24px; border-radius: 6px; border: 2px solid #cbd5e1; background: transparent; cursor: pointer; transition: 0.2s; padding: 0;" onmouseover="this.style.borderColor='#10b981'" onmouseout="this.style.borderColor='#cbd5e1'" title="Đánh dấu hoàn thành"></button>
                                    </form>
                                    
                                    <div>
                                        <h5 style="margin: 0; font-size: 1rem; font-weight: 600; color: #1e293b;">@task.Title</h5>
                                        <p style="margin: 4px 0 0 0; font-size: 0.85rem; color: #64748b; display: flex; align-items: center; gap: 8px; flex-wrap: wrap;">
                                            <span style="display: flex; align-items: center; gap: 4px; color: @(task.DueDate < DateTime.Now ? "#ef4444" : "inherit");">
                                                <svg width="14" height="14" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                                                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 8v4l3 3m6-3a9 9 0 11-18 0 9 9 0 0118 0z" />
                                                </svg>
                                                Hạn chót: @task.DueDate.ToString("dd/MM/yyyy HH:mm")
                                            </span>
                                            
                                            @if (task.DueDate < DateTime.Now)
                                            {
                                                <span style="background: #fee2e2; color: #ef4444; padding: 2px 8px; border-radius: 12px; font-size: 0.75rem; font-weight: 700; border: 1px solid #fca5a5;">
                                                    🔥 Đã quá hạn
                                                </span>
                                            }
                                            else
                                            {
                                                <span style="background: #dcfce3; color: #16a34a; padding: 2px 8px; border-radius: 12px; font-size: 0.75rem; font-weight: 700; border: 1px solid #86efac;">
                                                    ⏳ Chưa đến hạn
                                                </span>
                                            }
                                        </p>
                                    </div>
                                </div>

                                <div>
                                    <form asp-controller="Tasks" asp-action="Delete" asp-route-id="@task.Id" method="post" style="margin: 0;" onsubmit="return confirm('Bạn có chắc chắn muốn xóa công việc này không?');">
                                        <button type="submit" style="background: none; border: none; color: #cbd5e1; cursor: pointer; padding: 4px; transition: 0.2s;" onmouseover="this.style.color='#ef4444'" onmouseout="this.style.color='#cbd5e1'" title="Xóa công việc">
                                            <svg width="18" height="18" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 7l-.867 12.142A2 2 0 0116.138 21H7.862a2 2 0 01-1.995-1.858L5 7m5 4v6m4-6v6m1-10V4a1 1 0 00-1-1h-4a1 1 0 00-1 1v3M4 7h16" /></svg>
                                        </button>
                                    </form>
                                </div>

                            </div>
                        }
                    </div>
                }
                else
                {
                    <div style="text-align: center; padding: 40px 20px; color: #94a3b8; background: #f8fafc; border-radius: 12px; border: 1px dashed #cbd5e1;">
                        <span style="font-size: 2rem;">🎉</span><br/>
                        Tuyệt vời! Bạn không có việc nào đang tồn đọng.
                    </div>
                }
            </div>
        </div>
    </div>


    <div style="margin-top: 32px; background: white; border-radius: 16px; padding: 24px; box-shadow: 0 4px 15px rgba(0,0,0,0.03);">
        <h4 style="color: #64748b; font-weight: 700; margin-bottom: 20px; font-size: 1.1rem; display: flex; align-items: center; gap: 8px;">
            <svg width="22" height="22" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 12l2 2 4-4m6 2a9 9 0 11-18 0 9 9 0 0118 0z" /></svg>
            Lịch Sử Hoàn Thành (@completedTasks.Count)
        </h4>

        @if (completedTasks.Any())
        {
            <div style="display: grid; grid-template-columns: repeat(3, 1fr); gap: 16px;">
                @foreach (var task in completedTasks)
                {
                    <div class="task-item" style="border: 1px solid #e2e8f0; background: #f8fafc; border-radius: 12px; padding: 16px; display: flex; align-items: flex-start; justify-content: space-between; opacity: 0.75; transition: 0.3s;" onmouseover="this.style.opacity='1'; this.style.borderColor='#cbd5e1';" onmouseout="this.style.opacity='0.75'; this.style.borderColor='#e2e8f0';">
                        
                        <div style="display: flex; gap: 12px; align-items: flex-start;">
                            <form asp-controller="Tasks" asp-action="ToggleComplete" asp-route-id="@task.Id" method="post" style="margin: 0;" onsubmit="return confirm('Bạn muốn đánh dấu công việc này là CHƯA hoàn thành (Hoàn tác)?');">
                                <button type="submit" style="width: 24px; height: 24px; border-radius: 50%; border: none; background: #10b981; color: white; display: flex; align-items: center; justify-content: center; cursor: pointer; padding: 0; flex-shrink: 0;" title="Hoàn tác">
                                    <svg width="14" height="14" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="3" d="M5 13l4 4L19 7" /></svg>
                                </button>
                            </form>
                            
                            <div>
                                <h5 style="margin: 0; font-size: 1rem; font-weight: 600; color: #64748b;">@task.Title</h5>
                                
                                @if (!string.IsNullOrEmpty(task.Description))
                                {
                                    <p style="margin: 6px 0 0 0; font-size: 0.85rem; color: #94a3b8; display: -webkit-box; -webkit-line-clamp: 2; -webkit-box-orient: vertical; overflow: hidden;">@task.Description</p>
                                }
                            </div>
                        </div>
                        
                        <form asp-controller="Tasks" asp-action="Delete" asp-route-id="@task.Id" method="post" style="margin: 0; flex-shrink: 0;" onsubmit="return confirm('Bạn có chắc chắn muốn xóa vĩnh viễn công việc này khỏi lịch sử không?');">
                            <button type="submit" style="background: none; border: none; color: #cbd5e1; cursor: pointer; padding: 4px; transition: 0.2s;" onmouseover="this.style.color='#ef4444'" onmouseout="this.style.color='#cbd5e1'" title="Xóa vĩnh viễn">
                                <svg width="18" height="18" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 7l-.867 12.142A2 2 0 0116.138 21H7.862a2 2 0 01-1.995-1.858L5 7m5 4v6m4-6v6m1-10V4a1 1 0 00-1-1h-4a1 1 0 00-1 1v3M4 7h16" /></svg>
                            </button>
                        </form>
                    </div>
                }
            </div>
        }
        else
        {
            <div style="text-align: center; padding: 40px; color: #94a3b8; font-style: italic; background: #f8fafc; border-radius: 12px; border: 1px dashed #cbd5e1;">
                <svg width="48" height="48" fill="none" stroke="currentColor" viewBox="0 0 24 24" style="margin-bottom: 12px; opacity: 0.5;"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="1" d="M20 13V6a2 2 0 00-2-2H6a2 2 0 00-2 2v7m16 0v5a2 2 0 01-2 2H6a2 2 0 01-2-2v-5m16 0h-2.586a1 1 0 00-.707.293l-2.414 2.414a1 1 0 01-.707.293h-3.172a1 1 0 01-.707-.293l-2.414-2.414A1 1 0 006.586 13H4" /></svg>
                <br />
                Chưa có công việc nào được hoàn thành. Hãy bắt đầu chinh phục mục tiêu nhé! 💪
            </div>
        }
    </div>

    <div id="addTaskModal" class="modal" style="display: none; position: fixed; top: 0; left: 0; width: 100%; height: 100%; background: rgba(0,0,0,0.5); z-index: 1000; justify-content: center; align-items: center;">
        <div class="modal-content" style="background: white; padding: 24px; border-radius: 12px; width: 100%; max-width: 500px;">
            <div class="modal-header" style="display: flex; justify-content: space-between; align-items: center; border-bottom: 1px solid #eee; padding-bottom: 16px; margin-bottom: 16px;">
                <h3 style="margin: 0; font-size: 1.25rem;">Thêm Task</h3>
                <button type="button" onclick="closeAddTaskModal()" style="background: none; border: none; font-size: 1.5rem; cursor: pointer;">&times;</button>
            </div>
            <div class="modal-body">
                <form asp-controller="Tasks" asp-action="Create" method="post">
                    <div class="mb-3">
                        <label class="form-label fw-bold">Tiêu đề công việc <span class="text-danger">*</span></label>
                        <input type="text" name="Title" class="form-control" required />
                    </div>
                    <div class="mb-3">
                        <label class="form-label fw-bold">Mô tả chi tiết</label>
                        <textarea name="Description" class="form-control" rows="3"></textarea>
                    </div>
                    <div class="mb-3">
                        <label class="form-label fw-bold">Ngày giờ đến hạn <span class="text-danger">*</span></label>
                        <input type="datetime-local" name="DueDate" class="form-control" required />
                    </div>
                    <div class="text-end mt-4">
                        <button type="button" class="btn btn-light me-2 border" onclick="closeAddTaskModal()">Hủy</button>
                        <button type="submit" class="btn btn-primary">Lưu Công Việc</button>
                    </div>
                </form>
            </div>
        </div>
    </div>
</main>

@section Scripts {
    <script>
        function openAddTaskModal() { document.getElementById('addTaskModal').style.display = 'flex'; }
        function closeAddTaskModal() { document.getElementById('addTaskModal').style.display = 'none'; }
        window.onclick = function(event) { if (event.target == document.getElementById('addTaskModal')) closeAddTaskModal(); }


        // ==========================================
        // CHỨC NĂNG TÌM KIẾM TRỰC TIẾP (LIVE SEARCH)
        // ==========================================
        document.getElementById('taskSearchInput').addEventListener('input', function (e) {
            // Lấy từ khóa người dùng gõ và chuyển thành chữ thường
            var searchTerm = e.target.value.toLowerCase(); 
            
            // Lấy toàn bộ các khối công việc (cả chưa xong và đã xong)
            var taskItems = document.querySelectorAll('.task-item');

            taskItems.forEach(function (item) {
                // Lấy toàn bộ chữ bên trong khối đó (Tiêu đề, mô tả, ngày tháng)
                var text = item.textContent.toLowerCase();

                // Nếu nội dung chứa từ khóa tìm kiếm thì hiện, không thì ẩn
                if (text.includes(searchTerm)) {
                    item.style.display = ''; // Trả về trạng thái flex mặc định
                } else {
                    item.style.display = 'none'; // Ẩn đi hoàn toàn
                }
            });
        });
    </script>
}

@section Styles {
    <style>
        .custom-scroll::-webkit-scrollbar {
            width: 6px;
        }
        .custom-scroll::-webkit-scrollbar-track {
            background: transparent; 
        }
        .custom-scroll::-webkit-scrollbar-thumb {
            background-color: #cbd5e1; 
            border-radius: 10px; 
        }
        .custom-scroll::-webkit-scrollbar-thumb:hover {
            background-color: #94a3b8; 
        }
    </style>
}