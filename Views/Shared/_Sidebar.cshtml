@using System.Security.Claims
@{
    var currentController = ViewContext.RouteData.Values["controller"]?.ToString();
    var currentAction = ViewContext.RouteData.Values["action"]?.ToString();
}

<!-- Sidebar -->
<aside class="sidebar">
    <div class="sidebar-header">
        <div class="logo">
        <div class="logo-icon">📝</div>
        <span>NOTEAPP</span>
        </div>
    </div>

    <nav class="sidebar-nav">
        <div class="nav-section">
            <div class="nav-section-title">Chính</div>
            <a asp-controller="Home" asp-action="Index" class="nav-item @(currentController == "Home" && currentAction == "Index" ? "active" : "")">
                <svg
                class="nav-icon"
                fill="none"
                stroke="currentColor"
                viewBox="0 0 24 24"
                >
                <path
                    stroke-linecap="round"
                    stroke-linejoin="round"
                    stroke-width="2"
                    d="M3 12l2-2m0 0l7-7 7 7M5 10v10a1 1 0 001 1h3m10-11l2 2m-2-2v10a1 1 0 01-1 1h-3m-6 0a1 1 0 001-1v-4a1 1 0 011-1h2a1 1 0 011 1v4a1 1 0 001 1m-6 0h6"
                />
                </svg>
                <span>Trang chủ</span>
            </a>

            <a asp-controller="Prompts" asp-action="Index" class="nav-item @(currentController == "Prompts" && currentAction == "Index" ? "active" : "")">
                <svg
                class="nav-icon"
                fill="none"
                stroke="currentColor"
                viewBox="0 0 24 24"
                >
                <path
                    stroke-linecap="round"
                    stroke-linejoin="round"
                    stroke-width="2"
                    d="M8 10h.01M12 10h.01M16 10h.01M9 16H5a2 2 0 01-2-2V6a2 2 0 012-2h14a2 2 0 012 2v8a2 2 0 01-2 2h-5l-5 5v-5z"
                />
                </svg>
                <span>Prompts</span>
            </a>

            <a asp-controller="Notes" asp-action="Index" class="nav-item @(currentController == "Notes" && currentAction == "Index" ? "active" : "")">
                <svg
                class="nav-icon"
                fill="none"
                stroke="currentColor"
                viewBox="0 0 24 24"
                >
                <path
                    stroke-linecap="round"
                    stroke-linejoin="round"
                    stroke-width="2"
                    d="M11 5H6a2 2 0 00-2 2v11a2 2 0 002 2h11a2 2 0 002-2v-5m-1.414-9.414a2 2 0 112.828 2.828L11.828 15H9v-2.828l8.586-8.586z"
                />
                </svg>
                <span>Ghi chú</span>
            </a>
        </div>

        <div class="nav-section">
            <div class="nav-section-title">Bảo mật</div>
            <a asp-controller="Accounts" asp-action="Index" class="nav-item @(currentController == "Accounts" && currentAction == "Index" ? "active" : "")">
                <svg
                class="nav-icon"
                fill="none"
                stroke="currentColor"
                viewBox="0 0 24 24"
                >
                <path
                    stroke-linecap="round"
                    stroke-linejoin="round"
                    stroke-width="2"
                    d="M16 7a4 4 0 11-8 0 4 4 0 018 0zM12 14a7 7 0 00-7 7h14a7 7 0 00-7-7z"
                />
                </svg>
                <span>Tài khoản</span>
            </a>

            <a asp-controller="Tasks" asp-action="Index" class="nav-item @(currentController == "Tasks" && currentAction == "Index" ? "active" : "")">
                <svg
                class="nav-icon"
                fill="none"
                stroke="currentColor"
                viewBox="0 0 24 24"
                >
                <path
                    stroke-linecap="round"
                    stroke-linejoin="round"
                    stroke-width="2"
                    d="M9 5H7a2 2 0 00-2 2v12a2 2 0 002 2h10a2 2 0 002-2V7a2 2 0 00-2-2h-2M9 5a2 2 0 002 2h2a2 2 0 002-2M9 5a2 2 0 012-2h2a2 2 0 012 2"
                />
                </svg>
                <span>Tasks</span>
            </a>
        </div>



        @if (User.IsInRole("Admin"))
        {
            <div class="nav-section">
                <div class="nav-section-title">Quản trị hệ thống</div>

                @* Quản lý Người dùng *@
                <a asp-controller="Admin" asp-action="Users" class="nav-item @(currentController == "Admin" && currentAction == "Users" ? "active" : "")">
                    <svg class="nav-icon" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 4.354a4 4 0 110 5.292M15 21H3v-1a6 6 0 0112 0v1zm0 0h6v-1a6 6 0 00-9-5.197M13 7a4 4 0 11-8 0 4 4 0 018 0z" />
                    </svg>
                    <span>Người dùng</span>
                </a>

                @* Quản lý Tài khoản (Toàn hệ thống) *@
                <a asp-controller="Admin" asp-action="Accounts" class="nav-item @(currentController == "Admin" && currentAction == "Accounts" ? "active" : "")">
                    <svg class="nav-icon" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 12l2 2 4-4m5.618-4.016A11.955 11.955 0 0112 2.944a11.955 11.955 0 01-8.618 3.04A12.02 12.02 0 003 9c0 5.591 3.824 10.29 9 11.622 5.176-1.332 9-6.03 9-11.622 0-1.042-.133-2.052-.382-3.016z" />
                    </svg>
                    <span>Tài khoản</span>
                </a>

                @* Quản lý Ghi chú *@
                <a asp-controller="Admin" asp-action="Notes" class="nav-item @(currentController == "Admin" && currentAction == "Notes" ? "active" : "")">
                    <svg class="nav-icon" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 11H5m14 0a2 2 0 012 2v6a2 2 0 01-2 2H5a2 2 0 01-2-2v-6a2 2 0 012-2m14 0V9a2 2 0 00-2-2M5 11V9a2 2 0 012-2m0 0V5a2 2 0 012-2h6a2 2 0 012 2v2M7 7h10" />
                    </svg>
                    <span>Ghi chú</span>
                </a>

                @* Quản lý Tasks *@
                <a asp-controller="Admin" asp-action="Tasks" class="nav-item @(currentController == "Admin" && currentAction == "Tasks" ? "active" : "")">
                    <svg class="nav-icon" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 5H7a2 2 0 00-2 2v12a2 2 0 002 2h10a2 2 0 002-2V7a2 2 0 00-2-2h-2M9 5a2 2 0 002 2h2a2 2 0 002-2M9 5a2 2 0 012-2h2a2 2 0 012 2" />
                    </svg>
                    <span>Tasks</span>
                </a>


                <!-- Quản lý Prompt -->
                <a asp-controller="Admin" asp-action="Prompts" class="nav-item @(currentController == "Admin" && currentAction == "Prompts" ? "active" : "")">
                    <svg class="nav-icon" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                        <path
                    stroke-linecap="round"
                    stroke-linejoin="round"
                    stroke-width="2"
                    d="M8 10h.01M12 10h.01M16 10h.01M9 16H5a2 2 0 01-2-2V6a2 2 0 012-2h14a2 2 0 012 2v8a2 2 0 01-2 2h-5l-5 5v-5z"/>
                    </svg>
                    <span>Prompts</span>
                </a>
            </div>
        }
    </nav>

    <div class="sidebar-footer">
        <div class="user-profile">
            <div class="user-avatar">
                @(User.Identity?.Name?[..1].ToUpper() ?? "U")
            </div>
            <div class="user-info">
                <div class="user-name">@(User.Identity?.Name?.Split('@')[0] ?? "Khách")</div>

                <div class="user-email">
                    @User.FindFirst(ClaimTypes.Email)?.Value
                </div>
                <!-- <div class="user-email">@User.Identity?.Name</div> -->
            </div>
        </div>

        <form asp-controller="Auth" asp-action="Logout" method="post">
            <button type="submit" class="logout-btn">
                <svg class="nav-icon" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" 
                        d="M17 16l4-4m0 0l-4-4m4 4H7m6 4v1a3 3 0 01-3 3H6a3 3 0 01-3-3V7a3 3 0 013-3h4a3 3 0 013 3v1" />
                </svg>
                <span>Đăng xuất</span>
            </button>
        </form>
    </div>
</aside>