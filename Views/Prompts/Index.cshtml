@model IEnumerable<SecureNotesApp.Models.Prompt>

@{
    ViewData["Title"] = "Quản lý Prompts";

    // 1. Ép kiểu dữ liệu từ ViewBag về List để có thể dùng hàm .Count()
    var myPrompts = ViewBag.MyPrompts as List<SecureNotesApp.Models.Prompt> ?? new List<SecureNotesApp.Models.Prompt>();
    var commPrompts = ViewBag.CommunityPrompts as List<SecureNotesApp.Models.Prompt> ?? new List<SecureNotesApp.Models.Prompt>();

    // 2. Tính toán các con số thực tế
    var totalCount = myPrompts.Count + commPrompts.Count;
    var myCount = myPrompts.Count;
    var commCount = commPrompts.Count;
    var favCount = myPrompts.Count(p => p.IsFavorite); // Chỉ đếm yêu thích trong kho cá nhân

    // 3. Cập nhật lại danh sách stats để hiển thị
    var stats = new[] {
        new { Label = "Tổng Prompts", Value = totalCount.ToString(), IconPath = "M8 10h.01M12 10h.01M16 10h.01M9 16H5a2 2 0 01-2-2V6a2 2 0 012-2h14a2 2 0 012 2v8a2 2 0 01-2 2h-5l-5 5v-5z", Grad1 = "#6366f1", Grad2 = "#a855f7" },
        new { Label = "Của bạn", Value = myCount.ToString(), IconPath = "M16 7a4 4 0 11-8 0 4 4 0 018 0zM12 14a7 7 0 00-7 7h14a7 7 0 00-7-7z", Grad1 = "#3b82f6", Grad2 = "#2dd4bf" },
        new { Label = "Cộng đồng", Value = commCount.ToString(), IconPath = "M21 12a9 9 0 01-9 9m9-9a9 9 0 00-9-9m9 9H3m9 9a9 9 0 01-9-9m9 9c1.657 0 3-4.03 3-9s-1.343-9-3-9m0 18c-1.657 0-3-4.03-3-9s1.343-9 3-9m-9 9a9 9 0 019-9", Grad1 = "#f59e0b", Grad2 = "#ef4444" },
        new { Label = "Yêu thích", Value = favCount.ToString(), IconPath = "M4.318 6.318a4.5 4.5 0 000 6.364L12 20.364l7.682-7.682a4.5 4.5 0 00-6.364-6.364L12 7.636l-1.318-1.318a4.5 4.5 0 00-6.364 0z", Grad1 = "#ec4899", Grad2 = "#f43f5e" }
    };

    // 4. DỮ LIỆU DANH MỤC (Giữ nguyên để làm nút Lọc)
    var categories = new[] {
        new { Name = "Tất cả", Icon = "📝", IsActive = true },
        new { Name = "Công việc", Icon = "💼", IsActive = false },
        new { Name = "Lập trình", Icon = "💻", IsActive = false },
        new { Name = "Viết lách", Icon = "✍️", IsActive = false },
        new { Name = "Email", Icon = "📧", IsActive = false },
        new { Name = "Sáng tạo", Icon = "🎨", IsActive = false }
    };

    // Hàm phụ: Tính thời gian "vừa xong", "2 ngày trước"...
    string GetTimeAgo(DateTime date)
    {
        var span = DateTime.Now - date;
        if (span.Days > 30) return date.ToString("dd/MM/yyyy");
        if (span.Days > 0) return $"{span.Days} ngày trước";
        if (span.Hours > 0) return $"{span.Hours} giờ trước";
        if (span.Minutes > 0) return $"{span.Minutes} phút trước";
        return "Vừa xong";
    }
}

<div class="main-content">
    <div class="page-header">
        <div class="header-top">
            <h1 class="page-title">
                <span>💬</span> Prompts
            </h1>
            <div class="header-actions">
                <!-- <button class="btn btn-secondary">
                    <svg width="18" height="18" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 4a1 1 0 011-1h16a1 1 0 011 1v2.586a1 1 0 01-.293.707l-6.414 6.414a1 1 0 00-.293.707V17l-4 4v-6.586a1 1 0 00-.293-.707L3.293 7.293A1 1 0 013 6.586V4z" />
                    </svg> Lọc
                </button> -->
                <button class="btn btn-primary" onclick="openAddPromptModal()">
                    <svg width="18" height="18" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 4v16m8-8H4" />
                    </svg> Tạo Prompt Mới
                </button>
            </div>
        </div>

        <div class="search-bar">
            <svg class="search-icon" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M21 21l-6-6m2-5a7 7 0 11-14 0 7 7 0 0114 0z" />
            </svg>
            <input type="text" class="search-input" placeholder="Tìm kiếm prompts..." id="searchInput" />
        </div>
    </div>

    <div class="stats-grid">
        @foreach (var stat in stats)
        {
            <div class="stat-card">
                <div class="stat-icon" style="background: linear-gradient(135deg, @stat.Grad1 0%, @stat.Grad2 100%);">
                    <svg width="24" height="24" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="@stat.IconPath" />
                    </svg>
                </div>
                <div class="stat-content">
                    <div class="stat-label">@stat.Label</div>
                    <div class="stat-value">@stat.Value</div>
                </div>
            </div>
        }
    </div>

    <div class="categories-section">
        <h2 class="section-title">Danh mục</h2>
        <div class="categories-grid">
            @foreach (var cat in categories)
            {
                <button class="category-chip @(cat.IsActive ? "active" : "")" onclick="filterByCategory('@cat.Name', this)">
                    <span class="chip-icon">@cat.Icon</span> @cat.Name
                </button>
            }
        </div>
    </div>

    @* KHỐI 1: CỦA BẠN *@
    <div class="prompts-section">
        <h2 class="section-title">👤 Prompts của bạn</h2>
        <div class="prompts-grid" style="display: grid; grid-template-columns: repeat(auto-fill, minmax(300px, 1fr)); gap: 20px;">
            @if (ViewBag.MyPrompts != null)
            {
                @foreach (var p in (List<SecureNotesApp.Models.Prompt>)ViewBag.MyPrompts)
                {
                    @* Truyền IsMine = True *@
                    await Html.RenderPartialAsync("_PromptCard", p, new ViewDataDictionary(ViewData) { { "IsMine", "True" } });
                }
            }
        </div>
    </div>

    <hr style="margin: 40px 0; opacity: 0.1;" />

    @* KHỐI 2: CỘNG ĐỒNG *@
    <div class="prompts-section">
        <h2 class="section-title">🌐 Thư viện cộng đồng</h2>
        <div class="prompts-grid" style="display: grid; grid-template-columns: repeat(auto-fill, minmax(300px, 1fr)); gap: 20px;">
            @if (ViewBag.CommunityPrompts != null)
            {
                @foreach (var p in (List<SecureNotesApp.Models.Prompt>)ViewBag.CommunityPrompts)
                {
                    @* Truyền IsMine = False *@
                    await Html.RenderPartialAsync("_PromptCard", p, new ViewDataDictionary(ViewData) { { "IsMine", "False" } });
                }
            }
        </div>
    </div>
</div>



<!-- Model thêm -->
<div id="addPromptModal" class="modal" style="display: none; position: fixed; top: 0; left: 0; width: 100%; height: 100%; background: rgba(0,0,0,0.5); z-index: 1000; justify-content: center; align-items: center;">
    <div class="modal-content" style="background: white; padding: 24px; border-radius: 12px; width: 100%; max-width: 650px; box-shadow: 0 10px 25px rgba(0,0,0,0.1);">
        
        <div class="modal-header" style="display: flex; justify-content: space-between; align-items: center; border-bottom: 1px solid #eee; padding-bottom: 16px; margin-bottom: 16px;">
            <h3 style="margin: 0; font-size: 1.25rem;">Tạo Prompt Mới 💬</h3>
            <button type="button" onclick="closeAddPromptModal()" style="background: none; border: none; font-size: 1.5rem; cursor: pointer; color: #94a3b8;">&times;</button>
        </div>
        
        <div class="modal-body">
            <form asp-controller="Prompts" asp-action="Create" method="post">
                
                <div class="row">
                    <div class="col-md-7 mb-3">
                        <label class="form-label fw-bold">Tiêu đề <span class="text-danger">*</span></label>
                        <input type="text" name="Title" class="form-control" placeholder="VD: Viết email xin nghỉ phép..." required maxlength="150" />
                    </div>
                    <div class="col-md-5 mb-3">
                        <label class="form-label fw-bold">Danh mục <span class="text-danger">*</span></label>
                        
                        <select id="categorySelect" name="CategoryName" class="form-select form-control" required onchange="updateCategoryData()">
                            <option value="" disabled selected>-- Chọn --</option>
                            <option value="Công việc" data-icon="💼" data-class="business">💼 Công việc</option>
                            <option value="Lập trình" data-icon="💻" data-class="coding">💻 Lập trình</option>
                            <option value="Viết lách" data-icon="✍️" data-class="writing">✍️ Viết lách</option>
                            <option value="Email" data-icon="📧" data-class="email">📧 Email</option>
                            <option value="Sáng tạo" data-icon="🎨" data-class="creative">🎨 Sáng tạo</option>
                            <option value="Khác" data-icon="📝" data-class="other">📝 Khác</option>
                        </select>

                        <input type="hidden" name="CategoryIcon" id="hiddenCategoryIcon" />
                        <input type="hidden" name="CategoryClass" id="hiddenCategoryClass" />
                    </div>
                </div>
                
                <div class="mb-3">
                    <label class="form-label fw-bold">Mô tả ngắn</label>
                    <input type="text" name="Description" class="form-control" placeholder="Mô tả công dụng của prompt này (không bắt buộc)..." maxlength="500" />
                </div>

                <div class="mb-3">
                    <div class="form-check form-switch" style="display: flex; align-items: center; gap: 10px; background: #f8fafc; padding: 12px 12px 12px 40px; border-radius: 8px; border: 1px dashed #cbd5e1;">
                        <input class="form-check-input" type="checkbox" name="IsPublic" id="isPublicCheck" value="true" style="cursor: pointer; width: 2.5em; height: 1.25em;">
                        <label class="form-check-label fw-bold" for="isPublicCheck" style="cursor: pointer; color: #1e293b;">
                            Chia sẻ với cộng đồng 🌐
                        </label>
                    </div>
                    <small class="text-muted" style="font-size: 0.8rem; display: block; margin-top: 5px; margin-left: 2px;">
                        Nếu bật, người dùng khác có thể nhìn thấy và sử dụng Prompt này.
                    </small>
                </div>
                
                <div class="mb-3">
                    <label class="form-label fw-bold">Nội dung Prompt (Câu lệnh) <span class="text-danger">*</span></label>
                    <textarea name="Content" class="form-control" rows="5" placeholder="Nhập câu lệnh chi tiết dành cho AI vào đây..." required style="resize: vertical;"></textarea>
                </div>
                
                <div class="text-end mt-4">
                    <button type="button" class="btn btn-light me-2 border" onclick="closeAddPromptModal()">Hủy</button>
                    <button type="submit" class="btn btn-primary" style="background: linear-gradient(135deg, #667eea 0%, #764ba2 100%); border: none; font-weight: 600;">Lưu Prompt</button>
                </div>
            </form>
        </div>
    </div>
</div>


<!-- Model xem  -->
<div id="viewPromptModal" class="modal" style="display: none; position: fixed; top: 0; left: 0; width: 100%; height: 100%; background: rgba(0,0,0,0.5); z-index: 1000; justify-content: center; align-items: center;">
    <div class="modal-content" style="background: white; padding: 24px; border-radius: 12px; width: 100%; max-width: 600px; box-shadow: 0 10px 25px rgba(0,0,0,0.1);">
        
        <div class="modal-header" style="display: flex; justify-content: space-between; align-items: flex-start; border-bottom: 1px solid #eee; padding-bottom: 16px; margin-bottom: 16px;">
            <div>
                <h3 id="viewPromptTitle" style="margin: 0 0 8px 0; font-size: 1.25rem; color: #1e293b;">Tiêu đề</h3>
                <p id="viewPromptDesc" style="margin: 0; font-size: 0.9rem; color: #64748b;">Mô tả</p>
            </div>
            <button type="button" onclick="closeViewPromptModal()" style="background: none; border: none; font-size: 1.5rem; cursor: pointer; color: #94a3b8;">&times;</button>
        </div>
        
        <div class="modal-body">
            <label class="form-label fw-bold" style="color: #334155;">Nội dung câu lệnh (Prompt):</label>
            <textarea id="viewPromptContent" class="form-control" rows="6" readonly style="background: #f8fafc; font-family: monospace; font-size: 0.95rem; resize: none; margin-bottom: 20px; border: 1px solid #cbd5e1;"></textarea>
            
            <div class="text-end mt-2">
                <form id="incrementForm" asp-controller="Prompts" asp-action="IncrementUseCount" method="post" style="display: inline;">
                    <input type="hidden" name="id" id="viewPromptId" />
                    <button type="button" class="btn btn-light me-2 border" onclick="closeViewPromptModal()">Đóng</button>
                    
                    <button type="button" class="btn btn-primary" onclick="copyAndUsePrompt()" style="background: linear-gradient(135deg, #4facfe 0%, #00f2fe 100%); border: none;">
                        <svg width="18" height="18" fill="none" stroke="currentColor" viewBox="0 0 24 24" style="vertical-align: text-top; margin-right: 4px;">
                            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M8 16H6a2 2 0 01-2-2V6a2 2 0 012-2h8a2 2 0 012 2v2m-6 12h8a2 2 0 002-2v-8a2 2 0 00-2-2h-8a2 2 0 00-2 2v8a2 2 0 002 2z" />
                        </svg> Copy
                    </button>
                </form>
            </div>
        </div>
    </div>
</div>


<!-- Model sửa -->
<div id="editPromptModal" class="modal" style="display: none; position: fixed; top: 0; left: 0; width: 100%; height: 100%; background: rgba(0,0,0,0.5); z-index: 1000; justify-content: center; align-items: center;">
    <div class="modal-content" style="background: white; padding: 24px; border-radius: 12px; width: 100%; max-width: 650px; box-shadow: 0 10px 25px rgba(0,0,0,0.1);">
        
        <div class="modal-header" style="display: flex; justify-content: space-between; align-items: center; border-bottom: 1px solid #eee; padding-bottom: 16px; margin-bottom: 16px;">
            <h3 style="margin: 0; font-size: 1.25rem;">Chỉnh sửa Prompt ✏️</h3>
            <button type="button" onclick="closeEditPromptModal()" style="background: none; border: none; font-size: 1.5rem; cursor: pointer; color: #94a3b8;">&times;</button>
        </div>
        
        <div class="modal-body">
            <form asp-controller="Prompts" asp-action="Edit" method="post">
                <input type="hidden" name="Id" id="editPromptId" />
                
                <div class="row">
                    <div class="col-md-7 mb-3">
                        <label class="form-label fw-bold">Tiêu đề <span class="text-danger">*</span></label>
                        <input type="text" name="Title" id="editPromptTitle" class="form-control" required maxlength="150" />
                    </div>
                    <div class="col-md-5 mb-3">
                        <label class="form-label fw-bold">Danh mục <span class="text-danger">*</span></label>
                        <select id="editCategorySelect" name="CategoryName" class="form-select form-control" required onchange="updateEditCategoryData()">
                            <option value="Công việc" data-icon="💼" data-class="business">💼 Công việc</option>
                            <option value="Lập trình" data-icon="💻" data-class="coding">💻 Lập trình</option>
                            <option value="Viết lách" data-icon="✍️" data-class="writing">✍️ Viết lách</option>
                            <option value="Email" data-icon="📧" data-class="email">📧 Email</option>
                            <option value="Sáng tạo" data-icon="🎨" data-class="creative">🎨 Sáng tạo</option>
                            <option value="Khác" data-icon="📝" data-class="other">📝 Khác</option>
                        </select>
                        <input type="hidden" name="CategoryIcon" id="editHiddenCategoryIcon" />
                        <input type="hidden" name="CategoryClass" id="editHiddenCategoryClass" />
                    </div>
                </div>
                
                <div class="mb-3">
                    <label class="form-label fw-bold">Mô tả ngắn</label>
                    <input type="text" name="Description" id="editPromptDesc" class="form-control" maxlength="500" />
                </div>

                <div class="mb-3">
                    <div class="form-check form-switch" style="display: flex; align-items: center; gap: 10px; background: #fff7ed; padding: 12px 12px 12px 40px; border-radius: 8px; border: 1px dashed #fdba74;">
                        <input class="form-check-input" type="checkbox" name="IsPublic" id="editIsPublicCheck" value="true">
                        <label class="form-check-label fw-bold" for="editIsPublicCheck">Công khai cho cộng đồng 🌐</label>
                    </div>
                </div>
                
                <div class="mb-3">
                    <label class="form-label fw-bold">Nội dung Prompt <span class="text-danger">*</span></label>
                    <textarea name="Content" id="editPromptContent" class="form-control" rows="5" required style="resize: vertical;"></textarea>
                </div>
                
                <div class="text-end mt-4">
                    <button type="button" class="btn btn-light me-2 border" onclick="closeEditPromptModal()">Hủy</button>
                    <button type="submit" class="btn btn-primary" style="background: linear-gradient(135deg, #667eea 0%, #764ba2 100%); border: none;">Cập nhật</button>
                </div>
            </form>
        </div>
    </div>
</div>



@section Scripts {
    <script>
        // Đóng mở Popup
        function openAddPromptModal() { document.getElementById('addPromptModal').style.display = 'flex'; }
        function closeAddPromptModal() { document.getElementById('addPromptModal').style.display = 'none'; }
        function closeViewPromptModal() {
            document.getElementById('viewPromptModal').style.display = 'none';
        }
        function closeEditPromptModal() {
            document.getElementById('editPromptModal').style.display = 'none';
        }
        

        // Tự động trích xuất Icon và Class khi người dùng chọn Danh mục
        function updateCategoryData() {
            var select = document.getElementById("categorySelect");
            var selectedOption = select.options[select.selectedIndex];
            
            // Lấy data từ thẻ <option> và nhét vào thẻ <input type="hidden"> để gửi về Server
            document.getElementById("hiddenCategoryIcon").value = selectedOption.getAttribute("data-icon");
            document.getElementById("hiddenCategoryClass").value = selectedOption.getAttribute("data-class");
        }


        // Mở Modal Xem, đổ dữ liệu và TỰ ĐỘNG TĂNG LƯỢT XEM
        function openViewPromptModal(btn) {
            var promptId = btn.getAttribute('data-id');
            
            document.getElementById('viewPromptTitle').innerText = btn.getAttribute('data-title');
            document.getElementById('viewPromptDesc').innerText = btn.getAttribute('data-desc');
            document.getElementById('viewPromptContent').value = btn.getAttribute('data-content');
            
            document.getElementById('viewPromptModal').style.display = 'flex';

            fetch('/Prompts/IncrementUseCount/' + promptId, {
                method: 'POST'
            })
            .then(response => response.json())
            .then(data => {
                if (data.success) {
                    document.getElementById('useCount-' + promptId).innerText = data.newCount;
                    
                    btn.setAttribute('data-usecount', data.newCount); 
                }
            });
        }

        // Chức năng Copy vào Clipboard
        function copyAndUsePrompt() {
            var copyText = document.getElementById("viewPromptContent");
            
            navigator.clipboard.writeText(copyText.value).then(function() {
                alert("✅ Đã chép Prompt vào khay nhớ tạm!");
            }).catch(function(err) {
                alert("Lỗi khi copy: " + err);
            });
        }



        // 1. Hàm Mở Modal Sửa (Đây là nơi khởi tạo giá trị công khai)
        function openEditPromptModal(btn) {
            // Lấy tất cả dữ liệu từ data- attributes của nút bấm
            const id = btn.getAttribute('data-id');
            const title = btn.getAttribute('data-title');
            const category = btn.getAttribute('data-category');
            const desc = btn.getAttribute('data-desc');
            const content = btn.getAttribute('data-content');
            
            // TRÍCH XUẤT CÔNG KHAI: Chuyển text "True"/"False" thành kiểu boolean của JS
            const isPublicStr = btn.getAttribute('data-ispublic');
            const isPublic = (isPublicStr === 'True' || isPublicStr === 'true');

            // Đổ dữ liệu vào các ô Input (ID phải khớp với HTML)
            document.getElementById('editPromptId').value = id;
            document.getElementById('editPromptTitle').value = title;
            document.getElementById('editPromptDesc').value = desc;
            document.getElementById('editPromptContent').value = content;

            // CẬP NHẬT TRẠNG THÁI CHECKBOX CÔNG KHAI
            const publicCheck = document.getElementById('editIsPublicCheck');
            if (publicCheck) {
                publicCheck.checked = isPublic; 
            }

            // Xử lý Dropdown danh mục
            const select = document.getElementById('editCategorySelect');
            if (select) {
                select.value = category;
                updateEditCategoryData(); // Gọi hàm bên dưới để đồng bộ Icon/Class
            }

            document.getElementById('editPromptModal').style.display = 'flex';
        }

        // 2. Hàm đồng bộ Icon và Class khi đổi danh mục (Giữ nguyên và tối ưu)
        function updateEditCategoryData() {
            const select = document.getElementById('editCategorySelect');
            if (!select) return;

            const selectedOption = select.options[select.selectedIndex];
            
            if (selectedOption) {
                const icon = selectedOption.getAttribute('data-icon');
                const cssClass = selectedOption.getAttribute('data-class');

                document.getElementById('editHiddenCategoryIcon').value = icon;
                document.getElementById('editHiddenCategoryClass').value = cssClass;
            }
        }

        window.onclick = function(event) {
            var addModal = document.getElementById('addPromptModal');
            var viewModal = document.getElementById('viewPromptModal');
            var editModal = document.getElementById('editPromptModal'); 
            
            if (event.target == addModal) addModal.style.display = 'none';
            if (event.target == viewModal) viewModal.style.display = 'none';
            if (event.target == editModal) editModal.style.display = 'none';
        }

        // Filter
        function filterByCategory(categoryName, btnElement) {
            var chips = document.querySelectorAll('.category-chip');
            chips.forEach(function(chip) { chip.classList.remove('active'); });
            btnElement.classList.add('active');

            var cards = document.querySelectorAll('.prompt-card');
            cards.forEach(function(card) {
                var cardCategory = card.getAttribute('data-category');
                if (categoryName === 'Tất cả' || cardCategory === categoryName) {
                    card.style.display = 'flex';
                } else {
                    card.style.display = 'none';
                }
            });
        }


        document.addEventListener('DOMContentLoaded', function () {
        const searchInput = document.getElementById('searchInput');
        
        if (searchInput) {
            searchInput.addEventListener('input', function (e) {
                const searchTerm = e.target.value.toLowerCase().trim();
                const sections = document.querySelectorAll('.prompts-section');

                sections.forEach(section => {
                    const cards = section.querySelectorAll('.prompt-card');
                    let hasVisibleCard = false;

                    cards.forEach(card => {
                        const title = card.querySelector('.prompt-title')?.textContent.toLowerCase() || "";
                        const description = card.querySelector('.prompt-description')?.textContent.toLowerCase() || "";
                        const category = card.getAttribute('data-category')?.toLowerCase() || "";
                        const author = card.querySelector('.prompt-meta')?.textContent.toLowerCase() || "";

                        // Logic kiểm tra
                        const isMatch = title.includes(searchTerm) || 
                                        description.includes(searchTerm) || 
                                        category.includes(searchTerm) ||
                                        author.includes(searchTerm);

                        if (isMatch) {
                            card.style.display = "flex";
                            card.style.animation = "fadeIn 0.3s ease";
                            hasVisibleCard = true;
                        } else {
                            card.style.display = "none";
                        }
                    });

                    const sectionTitle = section.querySelector('.section-title');
                    const emptyMsg = section.querySelector('.empty-search-msg');

                    if (!hasVisibleCard && searchTerm !== "") {
                        if (!emptyMsg) {
                            const msg = document.createElement('div');
                            msg.className = 'empty-search-msg';
                            msg.innerHTML = `<div style="text-align:center; padding:20px; color:#94a3b8;">🔍 Không tìm thấy Prompt nào khớp với "${searchTerm}" trong phần này.</div>`;
                            section.querySelector('.prompts-grid').appendChild(msg);
                        }
                    } else {
                        if (emptyMsg) emptyMsg.remove();
                    }
                });
            });
        }
    });

    function handleEmptyResult() {
        const visibleCards = document.querySelectorAll('.prompt-card[style*="display: flex"]');
        // Bạn có thể thêm logic hiển thị thông báo "Không tìm thấy" ở đây nếu cần
    }
    </script>
}