@model IEnumerable<SecureNotesApp.Models.Note>

<div class="main-content">
    <div class="page-header">
        <div class="header-top">
            <h1 class="page-title">
                <span>💬</span> Ghi chú
            </h1>
            <div class="header-actions">
                <button class="btn btn-primary" onclick="openAddNoteModal()">
                    <svg width="18" height="18" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 4v16m8-8H4" />
                    </svg> Tạo Ghi chú mới
                </button>
            </div>
        </div>

        <div class="search-bar">
            <svg class="search-icon" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M21 21l-6-6m2-5a7 7 0 11-14 0 7 7 0 0114 0z" />
            </svg>
            <input type="text" class="search-input" placeholder="Tìm kiếm ghi chú..." id="searchInput" />
        </div>
    </div>

    <div class="notes-grid" style="display: grid; grid-template-columns: repeat(auto-fill, minmax(280px, 1fr)); gap: 20px;">
        @if (Model != null && Model.Any())
        {
            @foreach (var note in Model)
            {
                <div class="note-card" style="background: @note.Color; border-radius: 15px; padding: 20px; box-shadow: 0 4px 6px -1px rgba(0,0,0,0.1); border: 1px solid rgba(0,0,0,0.05); position: relative; transition: transform 0.2s;">
                    @if (note.IsPinned) {
                        <span style="position: absolute; top: -10px; right: 10px; font-size: 1.5rem;">📌</span>
                    }
                    
                    <h3 class="note-title" style="font-size: 1.1rem; font-weight: 700; color: #1e293b; margin-bottom: 10px;">@note.Title</h3>
                    <p class="note-content" style="color: #475569; font-size: 0.9rem; line-height: 1.6; white-space: pre-wrap;">@note.Content</p>
                    
                    <div class="note-footer" style="margin-top: 20px; display: flex; justify-content: space-between; align-items: center; border-top: 1px solid rgba(0,0,0,0.05); padding-top: 10px;">
                        <span style="font-size: 0.75rem; color: #64748b;">@note.CreatedAt.ToString("dd/MM/yyyy")</span>
                        <div class="actions">
                            <button class="btn-icon" title="Sửa" style="background:none; border:none; cursor:pointer;">
                                <svg width="18" height="18" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17 3a2.828 2.828 0 1 1 4 4L7.5 20.5 2 22l1.5-5.5L17 3z M14 7l-7 7"/>
                                </svg>                            
                            </button>
                            <button class="btn-icon" title="Xóa" style="background:none; border:none; cursor:pointer;">
                                <svg width="18" height="18" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 6h18 M19 6v14a2 2 0 0 1-2 2H7a2 2 0 0 1-2-2V6 M8 6V4a2 2 0 0 1 2-2h4a2 2 0 0 1 2 2v2 M10 11v6 M14 11v6" />
                                </svg>
                            </button>
                        </div>
                    </div>
                </div>
            }
        }
        else
        {
            <div style="grid-column: 1/-1; text-align: center; padding: 50px; background: #f8fafc; border-radius: 15px; border: 2px dashed #e2e8f0;">
                <div style="font-size: 3rem; margin-bottom: 10px;">💡</div>
                <h3 style="color: #64748b;">Bạn chưa có ghi chú nào</h3>
                <p style="color: #94a3b8;">Hãy bấm nút "Thêm ghi chú mới" để bắt đầu lưu lại ý tưởng!</p>
            </div>
        }
    </div>
</div>

@* --- MODAL THÊM GHI CHÚ (Sơ khai) --- *@
<div id="addNoteModal" class="modal" style="display:none; position:fixed; top:0; left:0; width:100%; height:100%; background:rgba(0,0,0,0.5); z-index:1000; align-items:center; justify-content:center;">
    <div style="background:white; padding:30px; border-radius:15px; width:500px;">
        <h3>Ghi chú mới 💡</h3>
        <form asp-action="Create" method="post">
            <input type="text" name="Title" class="form-control mb-3" placeholder="Tiêu đề..." required />
            <textarea name="Content" class="form-control mb-3" rows="5" placeholder="Nội dung ghi chú..." required></textarea>
            <label>Chọn màu sắc:</label>
            <div class="color-picker mb-3 d-flex gap-2">
                <input type="radio" name="Color" value="#fff9c4" checked /> 🟡
                <input type="radio" name="Color" value="#c8e6c9" /> 🟢
                <input type="radio" name="Color" value="#bbdefb" /> 🔵
                <input type="radio" name="Color" value="#ffcdd2" /> 🔴
            </div>
            <div class="text-end">
                <button type="button" onclick="closeAddNoteModal()" class="btn btn-light">Hủy</button>
                <button type="submit" class="btn btn-primary">Lưu ghi chú</button>
            </div>
        </form>
    </div>
</div>


<style>
    .note-card:hover {
        transform: translateY(-5px);
        box-shadow: 0 10px 15px -3px rgba(0,0,0,0.1);
    }
    .btn-icon {
        opacity: 0.6;
        transition: 0.2s;
    }
    .btn-icon:hover {
        opacity: 1;
        transform: scale(1.2);
    }
</style>

<script>
    function openAddNoteModal() { document.getElementById('addNoteModal').style.display = 'flex'; }
    function closeAddNoteModal() { document.getElementById('addNoteModal').style.display = 'none'; }
</script>